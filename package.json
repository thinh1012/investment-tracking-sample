{
  "name": "investment-tracking",
  "private": true,
  "version": "0.1.5",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron": "electron .",
    "start": "npm run start-desktop",
    "start-desktop": "npm run build && electron electron/main.js",
    "start-hq": "electron electron/main.js --hq",
    "start-system": "node scripts/orchestrator.js",
    "start-web": "npm start --prefix server",
    "lint": "eslint .",
    "test": "vitest",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "check:cycles": "npx madge --circular --extensions ts,tsx,js,jsx src/",
    "verify": "npm run check:cycles && npm run typecheck",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.digitalhq.vault",
    "productName": "Digital HQ",
    "directories": {
      "output": "H:/DigitalHQ/release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "satellite",
        "to": "satellite",
        "filter": [
          "**/*",
          "!node_modules/.cache/**"
        ]
      },
      {
        "from": "portable-node",
        "to": "portable-node",
        "filter": [
          "node.exe"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.87.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/react-window": "^1.8.8",
    "alasql": "^4.16.0",
    "better-sqlite3": "^12.5.0",
    "ethers": "^6.16.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.556.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-window": "^2.2.4",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.17",
    "autoprefixer": "^10.4.22",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "madge": "^8.0.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17"
  }
}
